{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>mason-org/registry-renovate-config",
    "config:recommended",
    ":semanticCommits",
    ":automergeBranch",
    ":skipStatusChecks",
    ":timezone(Asia/Ho_Chi_Minh)",
    ":disableRateLimiting"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor", "patch"],
      "automerge": true
    },
    {
      "description": "Fix Maven package lookup for JUnit by replacing slash with colon",
      "matchFileNames": ["packages/junit/package.yaml"],
      "matchDatasources": ["maven"],
      "matchPackageNames": [
        "org.junit.platform:junit-platform-console-standalone"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/package\\.yaml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "\nname: (?<depName>.+)",
        "\n  id:\\s+pkg:generic\\/(?<packageName>[^@]+)@(?<currentValue>[^\\s\\?#]+)",
        "# renovate:.*datasource=(?<datasource>[^,\n]+)",
        "# renovate:.*versioning=(?<versioning>[^,\n]+)"
      ],
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}",
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/package\\.yaml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "\nname: (?<depName>.+)",
        "\n  id:\\s+pkg:openvsx\\/(?<packageName>[^\\/]+\\/[^@]+)@(?<currentValue>[^\\s\\?#]+)",
        "# renovate:.*datasource=(?<datasource>[^,\n]+)",
        "# renovate:.*versioning=(?<versioning>[^,\n]+)"
      ],
      "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}custom.openvsx{{/if}}",
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/package\\.yaml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "\nname: (?<depName>.+)",
        "\n  id:\\s+pkg:golang\\/(?<packageName>.+)@(?<currentValue>[^\\s\\?#]+)",
        "# renovate:.*versioning=(?<versioning>[^,\n]+)"
      ],
      "datasourceTemplate": "go",
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    }
  ],
  "customDatasources": {
    "openvsx": {
      "defaultRegistryUrlTemplate": "https://open-vsx.org/api/{{{packageName}}}",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": $keys(allVersions)[$ != 'latest'] # $v . { \"version\": $string($v) } }"
      ]
    }
  }
}
