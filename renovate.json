{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>mason-org/registry-renovate-config",
    "config:recommended",
    ":semanticCommits",
    ":automergeBranch",
    ":skipStatusChecks",
    ":timezone(Asia/Ho_Chi_Minh)",
    ":disableRateLimiting"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor", "patch"],
      "automerge": true
    }
  ],
  "regexManagers": [
    {
      "fileMatch": "package\\.yaml$",
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "\nname: (?<depName>.+)",
        "\n  id:\\s+pkg:generic\\/(?<packageName>.+)@(?<currentValue>[^\\s\\?#]+)",
        "# renovate:.*versioning=(?<versioning>[^,\n]+)",
        "# renovate:.*datasource=maven"
      ],
      "datasourceTemplate": "{{{datasource}}}",
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}",
      "packageNameTemplate": "{{{replace '/' ':' packageName}}}",
      "currentValueTemplate": "{{{decodeURIComponent currentValue}}}"
    },
    {
      "fileMatch": "package\\.yaml$",
      "matchStrings": [
        "id:\\s*pkg:openvsx/(?<packageName>[^@]+)@(?<currentValue>[^\\s\\n]+)"
      ],
      "datasourceTemplate": "custom.openvsx",
      "depNameTemplate": "{{{packageName}}}"
    }
  ],
  "customDatasources": {
    "openvsx": {
      "defaultRegistryUrlTemplate": "https://open-vsx.org/api/{{{replace '.' '/' packageName}}}",
      "format": "json",
      "transformTemplates": [
        "{ \"releases\": $keys(allVersions)[$ != 'latest'] # $v . { \"version\": $v } }"
      ]
    }
  }
}
