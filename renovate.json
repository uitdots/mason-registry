{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>mason-org/registry-renovate-config",
    "config:recommended",
    ":semanticCommits",
    ":automergeBranch",
    ":skipStatusChecks",
    ":timezone(Asia/Ho_Chi_Minh)",
    ":disableRateLimiting"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor", "patch"],
      "automerge": true
    }
  ]
}
